// ============================================
// LifeOS - Prisma Schema
// PostgreSQL + Prisma
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_NON_POOLING")
}

// ----------------------------------------------------------
// ENUMS
// ----------------------------------------------------------

enum Role {
  USER
  ADMIN
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum Recurrence {
  NONE
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum PaymentMethod {
  CASH
  CREDIT_CARD
  DEBIT
  PIX
}

enum GoalCategory {
  FINANCIAL
  PERSONAL
  STUDIES
  FITNESS
  CAREER
  OTHER
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  PAUSED
  ARCHIVED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
}

enum ResourceStatus {
  TO_READ
  IN_PROGRESS
  DONE
  ARCHIVED
}

enum ResourceVaultCategory {
  ESTUDOS
  LAZER
  FERRAMENTAS
}

enum JourneyStepStatus {
  LOCKED
  IN_PROGRESS
  COMPLETED
}

// ----------------------------------------------------------
// USERS / AUTH
// ----------------------------------------------------------

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  passwordHash  String
  avatarUrl     String?
  role          Role     @default(USER)
  isApproved    Boolean  @default(false)
  emailVerified DateTime?
  onboardedAt   DateTime?
  timezone      String   @default("America/Sao_Paulo")
  locale        String   @default("pt-BR")
  currency      String   @default("BRL")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  refreshTokens     RefreshToken[]
  passwordResets    PasswordResetToken[]
  categories        Category[]
  transactions      FinancialTransaction[]
  goals             Goal[]
  habits            Habit[]
  habitLogs         HabitLog[]
  notifications     Notification[]
  preferences       UserPreferences?
  investments       Investment[]
  resources         Resource[]
  lifeBalance       LifeBalance?
  moodLogs          MoodLog[]
  journeys          Journey[]

  @@index([email])
}

model UserPreferences {
  id              String  @id @default(cuid())
  userId          String  @unique
  theme           String  @default("dark") // dark | light | system
  weeklyDigest    Boolean @default(true)
  emailReminders  Boolean @default(true)
  pushReminders   Boolean @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  userAgent  String?
  ip         String?
  revokedAt  DateTime?
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordResetToken {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ----------------------------------------------------------
// FINANCIAL
// ----------------------------------------------------------

model Category {
  id        String          @id @default(cuid())
  userId    String
  name      String
  color     String          @default("#6366f1")
  icon      String?
  type      TransactionType @default(EXPENSE)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  user         User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions FinancialTransaction[]

  @@unique([userId, name, type])
  @@index([userId])
}

model FinancialTransaction {
  id          String          @id @default(cuid())
  userId      String
  categoryId  String?
  type        TransactionType
  amount      Decimal         @db.Decimal(14, 2)
  description String
  notes       String?
  date        DateTime
  recurrence  Recurrence      @default(NONE)
  paymentMethod PaymentMethod @default(CASH)
  installments  Int           @default(1)
  isCreditCard Boolean        @default(false)
  installmentGroupId String?
  installmentNumber  Int?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([userId, date])
  @@index([categoryId])
  @@index([userId, installmentGroupId])
}

// ----------------------------------------------------------
// GOALS
// ----------------------------------------------------------

model Goal {
  id          String       @id @default(cuid())
  userId      String
  title       String
  description String?
  category    GoalCategory @default(PERSONAL)
  targetValue Decimal?     @db.Decimal(14, 2)
  currentValue Decimal     @default(0) @db.Decimal(14, 2)
  progress    Int          @default(0) // 0-100
  priority    Priority     @default(MEDIUM)
  status      GoalStatus   @default(ACTIVE)
  deadline    DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

// ----------------------------------------------------------
// HABITS
// ----------------------------------------------------------

model Habit {
  id           String   @id @default(cuid())
  userId       String
  title        String
  description  String?
  icon         String?
  color        String   @default("#22c55e")
  targetPerDay Int      @default(1)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs HabitLog[]

  @@index([userId, active])
}

model HabitLog {
  id        String   @id @default(cuid())
  habitId   String
  userId    String
  date      DateTime @db.Date
  count     Int      @default(1)
  note      String?
  createdAt DateTime @default(now())

  habit Habit @relation(fields: [habitId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([habitId, date])
  @@index([userId, date])
}

// ----------------------------------------------------------
// NOTIFICATIONS
// ----------------------------------------------------------

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType @default(INFO)
  title     String
  message   String
  link      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

// ----------------------------------------------------------
// INVESTMENTS
// ----------------------------------------------------------

model Investment {
  id        String   @id @default(cuid())
  userId    String
  name      String
  amount    Decimal  @db.Decimal(14, 2)
  type      String   // CDB, Tesouro, Ações, FIIs, ETFs, Cripto, Outros, ...
  color     String   @default("#22c55e")
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ----------------------------------------------------------
// RESOURCES (Vault) — links / artigos / recursos para depois
// ----------------------------------------------------------

model Resource {
  id            String               @id @default(cuid())
  userId        String
  title         String
  url           String
  description   String?
  // Categoria principal: Estudos, Lazer ou Ferramentas
  vaultCategory ResourceVaultCategory @default(ESTUDOS)
  // Rótulo legado opcional (Artigo, Vídeo, etc.)
  category      String?
  status        ResourceStatus       @default(TO_READ)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, vaultCategory])
}

// ----------------------------------------------------------
// RODA DA VIDA — Life Balance Wheel (um registro por usuário)
// ----------------------------------------------------------

model LifeBalance {
  id              String   @id @default(cuid())
  userId          String   @unique
  saude           Int      @default(5) // Saúde (0-10)
  carreira        Int      @default(5) // Carreira (0-10)
  financas        Int      @default(5) // Finanças (0-10)
  relacionamentos Int      @default(5) // Relacionamentos (0-10)
  lazer           Int      @default(5) // Lazer (0-10)
  pessoal         Int      @default(5) // Desenvolvimento Pessoal (0-10)
  espiritualidade Int      @default(5) // Espiritualidade (0-10)
  contribuicao    Int      @default(5) // Contribuição Social (0-10)
  notes           String?
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ----------------------------------------------------------
// DIÁRIO DE HUMOR — Mood Tracker (um registro por dia)
// ----------------------------------------------------------

model MoodLog {
  id        String   @id @default(cuid())
  userId    String
  mood      String   // "awful" | "bad" | "okay" | "good" | "great"
  note      String?
  date      DateTime @db.Date
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

// ----------------------------------------------------------
// JORNADA — missões gamificadas (árvore de passos)
// ----------------------------------------------------------

model Journey {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  createdAt   DateTime @default(now())

  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  steps JourneyStep[]

  @@index([userId])
}

model JourneyStep {
  id          String             @id @default(cuid())
  journeyId   String
  title       String
  description String?
  url         String?
  instructor  String?
  difficulty  Int                @default(1)
  xpReward    Int                @default(100)
  order       Int
  status      JourneyStepStatus  @default(LOCKED)

  journey Journey @relation(fields: [journeyId], references: [id], onDelete: Cascade)

  @@index([journeyId, order])
}
