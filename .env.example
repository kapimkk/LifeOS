# ============================================
# LifeOS - Environment Variables (example)
# Copie este arquivo para `.env` e preencha os valores.
# ============================================

# ---- Database (PostgreSQL) ----
# Quando rodando via docker-compose use o hostname `db`
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/lifeos?schema=public"

# ---- App ----
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- JWT / Auth ----
# Gere segredos fortes (ex.: openssl rand -base64 64)
JWT_ACCESS_SECRET="change-me-access-secret-min-32-characters"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-characters"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ---- Cookies ----
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# ---- IA (Google Gemini) ----
# Obtenha em https://aistudio.google.com/app/apikey
# Se omitida, as features de IA ficam desabilitadas graciosamente.
GEMINI_API_KEY=
